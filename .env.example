# Environment Variables Template
# Copy this file to .env.development.local for local development

# Vercel Postgres Database URLs (from vercel env pull)
# Development/Preview uses DEV_STORAGE_* prefix
DEV_STORAGE_PRISMA_DATABASE_URL="your-dev-prisma-url-here"
DEV_STORAGE_POSTGRES_URL="your-dev-postgres-url-here"

# Production uses PROD_STORAGE_* prefix
PROD_STORAGE_PRISMA_DATABASE_URL="your-prod-prisma-url-here"
PROD_STORAGE_POSTGRES_URL="your-prod-postgres-url-here"

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
