generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TestTable {
  id          String   @id @default(cuid())
  name        String @unique
  createdAt   DateTime @default(now())

  @@map("TestTable")
}

model User {
  id String @id @default(cuid())
  name String
  mainWalletPublicKey String @unique
  mainWallet Wallet @relation("UserMainWallet", fields: [mainWalletPublicKey], references: [publicKey])
  wallets Wallet[] @relation("WalletUser")
  tokens Token[] @relation("TokenUser")
  launches Launch[] @relation("LaunchUser")
  holdingExits HoldingExit[] @relation("HoldingExitUser")
  volumeBotSessions VolumeBotSession[] @relation("VolumeBotSessionUser")
  volumeBotPresets VolumeBotPreset[] @relation("VolumeBotPresetUser")
  vanityMints VanityMint[] @relation("VanityMintUser")
  refreshCaches RefreshCache[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("User")
}

model Wallet {
  publicKey String @id @unique
  privateKey String @unique
  type WalletType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User? @relation("WalletUser", fields: [userId], references: [id])
  userId String?
  mainWalletUser User? @relation("UserMainWallet")
  tokenPublicKey String?
  token Token? @relation("TokenOperationalWallets", fields: [tokenPublicKey], references: [publicKey])
  balanceSol Decimal @default(0)
  balanceRefreshedAt DateTime?
  isImported Boolean @default(false)
  holdings Holding[] @relation("WalletHoldings")
  transactions Transaction[] @relation("WalletTransactions")
  tokenTransactions TokenTransaction[] @relation("WalletTokenTransactions")
  devWalletTokens TokenDevWallet[] @relation("DevWalletTokens")
  volumeBotWallets VolumeBotWallet[] @relation("VolumeBotWallets")
  launchRecoveryWallets LaunchRecoveryWallet[] @relation("LaunchRecoveryWalletRecordWallet")
  @@map("Wallet")
}

enum WalletType {
  MAIN_WALLET
  DEV
  BUNDLER
  VOLUME
  DISTRIBUTION
}

enum TokenStatus {
  PENDING
  ACTIVE
  FAILED
}

model Token {
  publicKey String @id @unique
  privateKey String @unique
  status TokenStatus @default(PENDING)
  name String
  symbol String
  description String?
  imageUrl String?
  websiteUrl String?
  twitterUrl String?
  telegramUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId String
  user User @relation("TokenUser", fields: [userId], references: [id])
  operationalWallets Wallet[] @relation("TokenOperationalWallets")
  devWallets TokenDevWallet[] @relation("TokenDevWallets")
  holdings Holding[] @relation("TokenHoldings")
  transactions Transaction[] @relation("TokenTransactions")
  tokenTransactions TokenTransaction[] @relation("TokenTokenTransactions")
  refreshCaches RefreshCache[]
  launches Launch[] @relation("LaunchToken")
  holdingExits HoldingExit[] @relation("HoldingExitToken")
  volumeBotSessions VolumeBotSession[] @relation("VolumeBotSessionToken")
  vanityMints VanityMint[]
  @@map("Token")
}

model TokenDevWallet {
  tokenPublicKey String
  walletPublicKey String
  token Token @relation("TokenDevWallets", fields: [tokenPublicKey], references: [publicKey])
  wallet Wallet @relation("DevWalletTokens", fields: [walletPublicKey], references: [publicKey])
  @@id([tokenPublicKey, walletPublicKey])
  @@map("TokenDevWallet")
}

enum LaunchStatus {
  PENDING
  RUNNING
  CANCELED
  FAILED
  SUCCEEDED
}

enum LaunchLogLevel {
  INFO
  WARN
  ERROR
  STEP
}

enum LaunchRecoveryWalletRole {
  DEV
  BUNDLER
  DISTRIBUTION
}

enum LaunchRecoveryWalletStatus {
  ELIGIBLE
  RETURNED
  FAILED
  SKIPPED
}

enum HoldingExitStatus {
  PENDING
  RUNNING
  FAILED
  SUCCEEDED
}

enum HoldingExitLogLevel {
  INFO
  WARN
  ERROR
  STEP
}

enum VolumeBotSessionStatus {
  DRAFT
  SCHEDULED
  RUNNING
  STOP_REQUESTED
  STOPPING
  STOPPED
  FAILED
}

enum VolumeBotLogLevel {
  INFO
  WARN
  ERROR
  TRADE
}

enum VolumeBotWalletRole {
  TRADER
}

enum VolumeBotWalletStatus {
  ACTIVE
  PAUSED
  RECLAIMED
  FAILED
}

model Launch {
  id String @id @default(cuid())
  userId String
  user User @relation("LaunchUser", fields: [userId], references: [id])
  status LaunchStatus @default(PENDING)
  progress Int @default(0)
  currentStep String?
  input Json
  result Json?
  tokenPublicKey String?
  token Token? @relation("LaunchToken", fields: [tokenPublicKey], references: [publicKey])
  startedAt DateTime?
  completedAt DateTime?
  cancelRequestedAt DateTime?
  errorMessage String?
  logs LaunchLog[] @relation("LaunchLogs")
  recoveryWallets LaunchRecoveryWallet[] @relation("LaunchRecoveryWalletRecordLaunch")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("Launch")
}

model LaunchLog {
  id String @id @default(cuid())
  launchId String
  launch Launch @relation("LaunchLogs", fields: [launchId], references: [id])
  level LaunchLogLevel
  message String
  step String?
  data Json?
  createdAt DateTime @default(now())
  @@map("LaunchLog")
}

model LaunchRecoveryWallet {
  id String @id @default(cuid())
  launchId String
  launch Launch @relation("LaunchRecoveryWalletRecordLaunch", fields: [launchId], references: [id])
  walletPublicKey String
  wallet Wallet @relation("LaunchRecoveryWalletRecordWallet", fields: [walletPublicKey], references: [publicKey])
  walletType WalletType
  role LaunchRecoveryWalletRole
  isManaged Boolean @default(true)
  reclaimStatus LaunchRecoveryWalletStatus @default(ELIGIBLE)
  reclaimTxSignature String?
  reclaimError String?
  lastAttemptAt DateTime?
  reclaimedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([launchId, walletPublicKey])
  @@index([launchId, reclaimStatus])
  @@map("LaunchRecoveryWallet")
}

model HoldingExit {
  id String @id @default(cuid())
  userId String
  user User @relation("HoldingExitUser", fields: [userId], references: [id])
  tokenPublicKey String
  token Token @relation("HoldingExitToken", fields: [tokenPublicKey], references: [publicKey])
  status HoldingExitStatus @default(PENDING)
  progress Int @default(0)
  currentStep String?
  input Json
  result Json?
  startedAt DateTime?
  completedAt DateTime?
  errorMessage String?
  logs HoldingExitLog[] @relation("HoldingExitLogs")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, tokenPublicKey, status])
  @@map("HoldingExit")
}

model HoldingExitLog {
  id String @id @default(cuid())
  exitId String
  exit HoldingExit @relation("HoldingExitLogs", fields: [exitId], references: [id])
  level HoldingExitLogLevel
  message String
  step String?
  data Json?
  createdAt DateTime @default(now())
  @@index([exitId, createdAt])
  @@map("HoldingExitLog")
}

model VolumeBotSession {
  id String @id @default(cuid())
  userId String
  user User @relation("VolumeBotSessionUser", fields: [userId], references: [id])
  tokenPublicKey String
  token Token @relation("VolumeBotSessionToken", fields: [tokenPublicKey], references: [publicKey])
  status VolumeBotSessionStatus @default(DRAFT)
  config Json
  scheduledStartAt DateTime?
  startedAt DateTime?
  stopRequestedAt DateTime?
  scheduledStopAt DateTime?
  stoppedAt DateTime?
  lastTickAt DateTime?
  totalVolumeUsd Decimal @default(0)
  totalTrades Int @default(0)
  totalPnlSol Decimal @default(0)
  runtimeSeconds Int @default(0)
  wallets VolumeBotWallet[] @relation("VolumeBotSessionWallets")
  logs VolumeBotLog[] @relation("VolumeBotSessionLogs")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, status])
  @@index([tokenPublicKey, status])
  @@map("VolumeBotSession")
}

model VolumeBotPreset {
  id String @id @default(cuid())
  userId String
  user User @relation("VolumeBotPresetUser", fields: [userId], references: [id])
  name String
  config Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, name])
  @@index([userId, updatedAt])
  @@map("VolumeBotPreset")
}

model VolumeBotWallet {
  id String @id @default(cuid())
  sessionId String
  session VolumeBotSession @relation("VolumeBotSessionWallets", fields: [sessionId], references: [id])
  walletPublicKey String
  wallet Wallet @relation("VolumeBotWallets", fields: [walletPublicKey], references: [publicKey])
  role VolumeBotWalletRole @default(TRADER)
  status VolumeBotWalletStatus @default(ACTIVE)
  solBalance Decimal @default(0)
  tokenBalance Decimal @default(0)
  tradesExecuted Int @default(0)
  pnlSol Decimal @default(0)
  lastTradeAt DateTime?
  nextTickAt DateTime?
  pausedAt DateTime?
  pauseReason String?
  reclaimedAt DateTime?
  reclaimTxSignature String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([sessionId, walletPublicKey])
  @@index([sessionId, status])
  @@index([status, nextTickAt])
  @@index([walletPublicKey])
  @@map("VolumeBotWallet")
}

model VolumeBotLog {
  id String @id @default(cuid())
  sessionId String
  session VolumeBotSession @relation("VolumeBotSessionLogs", fields: [sessionId], references: [id])
  level VolumeBotLogLevel
  type String
  message String
  data Json?
  walletPublicKey String?
  signature String?
  createdAt DateTime @default(now())
  @@index([sessionId, createdAt])
  @@map("VolumeBotLog")
}

model VanityMint {
  id String @id @default(cuid())
  publicKey String @unique
  privateKey String @unique
  reservedAt DateTime?
  usedAt DateTime?
  tokenPublicKey String?
  token Token? @relation(fields: [tokenPublicKey], references: [publicKey])
  userId String?
  user User? @relation("VanityMintUser", fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("VanityMint")
}

model Holding {
  id String @id @default(cuid())
  walletPublicKey String
  tokenPublicKey String
  tokenBalance Decimal
  totalBuyAmount Decimal
  totalSellAmount Decimal
  averageBuyPrice Decimal
  lastTransactionSignature String
  lastUpdated DateTime @default(now())
  createdAt DateTime @default(now())
  wallet Wallet @relation("WalletHoldings", fields: [walletPublicKey], references: [publicKey])
  token Token @relation("TokenHoldings", fields: [tokenPublicKey], references: [publicKey])
  mintAddress String
  tokenName String
  tokenSymbol String
  tokenImageUrl String
  tokenDecimals Int
  @@index([tokenPublicKey, walletPublicKey])
  @@index([tokenPublicKey, lastUpdated])
  @@map("Holding")
}

enum TransactionType {
  BUY
  SELL
  CREATE
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum RefreshScope {
  TRANSACTIONS
  HOLDINGS
  WALLETS
}

model Transaction {
  id String @id @default(cuid())
  walletPublicKey String
  wallet Wallet @relation("WalletTransactions", fields: [walletPublicKey], references: [publicKey])
  tokenPublicKey String
  token Token @relation("TokenTransactions", fields: [tokenPublicKey], references: [publicKey])
  transactionType TransactionType
  status TransactionStatus
  transactionSignature String
  solAmount Decimal
  tokenAmount Decimal
  pricePerToken Decimal
  slippageBps Int
  feeAmount Decimal
  blockTime DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tokenPublicKey, createdAt])
  @@index([tokenPublicKey, walletPublicKey, createdAt])
  @@index([walletPublicKey, tokenPublicKey, createdAt])
  @@index([tokenPublicKey, transactionSignature, walletPublicKey])
  @@index([tokenPublicKey, updatedAt])
  @@map("Transaction")
}

model TokenTransaction {
  id String @id @default(cuid())
  walletPublicKey String
  walletRefPublicKey String?
  walletRef Wallet? @relation("WalletTokenTransactions", fields: [walletRefPublicKey], references: [publicKey])
  tokenPublicKey String
  token Token @relation("TokenTokenTransactions", fields: [tokenPublicKey], references: [publicKey])
  walletType WalletType?
  isOwned Boolean @default(false)
  transactionType TransactionType
  status TransactionStatus
  transactionSignature String
  solAmount Decimal
  tokenAmount Decimal
  pricePerToken Decimal
  slippageBps Int
  feeAmount Decimal
  blockTime DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tokenPublicKey, transactionSignature, walletPublicKey, transactionType])
  @@index([tokenPublicKey, createdAt])
  @@index([walletPublicKey, tokenPublicKey, createdAt])
  @@map("TokenTransaction")
}

model RefreshCache {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  tokenPublicKey String?
  token Token? @relation(fields: [tokenPublicKey], references: [publicKey])
  scope RefreshScope
  lastRefreshedAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, tokenPublicKey, scope])
  @@map("RefreshCache")
}

model ShyftCallback {
  id String @id @default(cuid())
  callbackId String @unique
  type String
  address String
  projectId String?
  createdAt DateTime @default(now())
  @@map("ShyftCallback")
}